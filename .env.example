# 以下密钥均需用 dart run _encrypt_temp.dart 加密后填入，避免明文存储。
AGNES_API_KEY=your_agnes_api_key_encrypted
AGNES_V1_KEY=your_agnes_v1_api_key_encrypted
TAVILY_API_KEY=your_tavily_api_key_encrypted
SEARXNG_BASE_URL=http://your-searxng-domain-or-ip:port
# 可选：APK 下载地址（国内用 Gitee），{version} 会自动替换为最新版本号
# UPDATE_APK_URL=https://gitee.com/用户名/仓库名/releases/download/{version}/app-release.apk
# 高德地图 Web 服务 API Key（天气查询），免费申请：https://lbs.amap.com/api/webservice/guide/create-project
GAODE_API_KEY=your_gaode_api_key_encrypted
